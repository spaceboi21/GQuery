# Copy to .env and fill in your values.
# All variables are optional — defaults work out of the box with OpenAI.

# Where your Excel/CSV files live
XIA_DATA_PATH=C:/Users/YourName/Documents/Excel

# LLM provider: openai | anthropic | ollama
XIA_LLM_PROVIDER=openai
XIA_LLM_MODEL=gpt-4o-mini
XIA_LLM_API_KEY=sk-...

# Ollama (local, no key needed)
# XIA_LLM_PROVIDER=ollama
# XIA_LLM_MODEL=llama3:8b
# XIA_LLM_BASE_URL=http://localhost:11434/v1

# Anthropic
# XIA_LLM_PROVIDER=anthropic
# XIA_LLM_MODEL=claude-3-5-haiku-20241022
# XIA_LLM_API_KEY=sk-ant-...

# App server (leave as-is for local use)
XIA_APP_HOST=127.0.0.1
XIA_APP_PORT=8000
